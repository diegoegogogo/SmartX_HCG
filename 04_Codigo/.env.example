# SmartX — Configuración de Entorno
# Copia este archivo como .env y ajusta los valores según necesites

# ═══════════════════════════════════════════════════════════════════════════════
# API — Backend FastAPI
# ═══════════════════════════════════════════════════════════════════════════════

# URL base del backend (desarrollo)
SMARTX_API_URL=http://127.0.0.1:8000

# Puerto en el que corre FastAPI
FASTAPI_PORT=8000

# Modo de ejecución (development | production)
FASTAPI_ENV=development

# ═══════════════════════════════════════════════════════════════════════════════
# STREAMLIT — Frontend
# ═══════════════════════════════════════════════════════════════════════════════

# Puerto en el que corre Streamlit (por defecto 8501)
STREAMLIT_PORT=8501

# ═══════════════════════════════════════════════════════════════════════════════
# LOGGING
# ═══════════════════════════════════════════════════════════════════════════════

# Nivel de logging (DEBUG | INFO | WARNING | ERROR | CRITICAL)
LOG_LEVEL=INFO

# ═══════════════════════════════════════════════════════════════════════════════
# CACHING
# ═══════════════════════════════════════════════════════════════════════════════

# Directorio de caché para joblib/scikit-learn
CACHE_DIR=./cachedir

# ═══════════════════════════════════════════════════════════════════════════════
# NOTAS IMPORTANTES
# ═══════════════════════════════════════════════════════════════════════════════

# 1. Frontend debe acceder al backend en la misma URL que pone aquí
#    Si el backend corre en otra máquina, actualiza SMARTX_API_URL
#
# 2. El archivo .env no se sube a git (ver .gitignore)
#
# 3. En producción, usar valores reales y seguros (no "127.0.0.1")
#
# 4. Para CORS, el backend ya permite ambos puertos en desarrollo
